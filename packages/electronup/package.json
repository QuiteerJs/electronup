{
  "name": "electronup",
  "version": "0.2.0",
  "description": "融合构建 electron 应用需要的构建工具,保留原有配置习惯的命令行工具 ",
  "author": "quiteer",
  "license": "MIT",
  "homepage": "https://github.com/QuiteerJs/electronup#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuiteerJs/electronup.git"
  },
  "bugs": {
    "url": "https://github.com/QuiteerJs/electronup/issues"
  },
  "keywords": [
    "vite",
    "tsdown",
    "electron-builder",
    "electron"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.mjs"
      }
    },
    "bin": {
      "electronup": "dist/bin/electronup.mjs"
    },
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": "./index.ts"
  },
  "main": "dist/client/index.mjs",
  "module": "dist/client/index.mjs",
  "types": "dist/client/index.d.mts",
  "bin": {
    "electronup": "./dev.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "release": "qui r --tag-prefix electronup && tsdown && pnpm publish"
  },
  "peerDependencies": {
    "@types/node": ">= 22",
    "node": ">= 22",
    "vue": ">= 3"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@quiteer/parser-config": "^1.0.3",
    "cac": "^7.0.0",
    "dotenv": "^17.3.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "fs-extra": "^11.3.3",
    "kolorist": "^1.8.0",
    "portfinder": "^1.0.38",
    "tsdown": "^0.20.3",
    "vite": "^8.0.0-beta.13",
    "yaml": "^2.8.2"
  }
}
