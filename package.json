{
  "name": "electronup-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@8.6.7",
  "description": "融合构建 electron 应用需要的构建工具,保留原有配置习惯的命令行工具 ",
  "author": "quiteer",
  "license": "MIT",
  "homepage": "https://github.com/QuiteerJs/electronup#readme",
  "scripts": {
    "work:dev": "pnpm --filter './packages/*' dev",
    "work:build": "pnpm --filter './packages/*' build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "template:run": "pnpm --filter './template/*' dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "commit": "qui gc"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@quiteer/scripts": "^0.1.6",
    "@quiteer/ts-config": "^0.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.3.1",
    "eslint": "^10.0.2",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitepress": "1.6.4"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm qui gv",
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
